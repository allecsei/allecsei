function getPlayerWanted()
    return memory.getuint8(0x58DB60) or 0
end

function getReserveOfBreath()
    local float = memory.getfloat(0xB7CDE0) or 0.0
    return float / 39.97000244
end

function getReserveOfStamina()
    local float = memory.getfloat(0xB7CDB4) or 0.0
    return float / 31.47000244
end

function getAmmoInClip()
    local pointer = getCharPointer(PLAYER_PED)
    if not pointer or pointer == 0 then
        return 0
    end

    local weapon = getCurrentCharWeapon(PLAYER_PED)
    if not weapon or weapon == 0 then
        return 0
    end

    local slot = getWeapontypeSlot(weapon)
    if not slot then
        return 0
    end

    local offset = pointer + 0x5A0
    local address = offset + slot * 0x1C
    return memory.getuint32(address + 0x8)
end

function int_separator(value)
    local str = tostring(value or 0)
    local sign = ""
    if str:sub(1, 1) == "-" then
        sign = "-"
        str = str:sub(2)
    end

    local formatted = str:reverse():gsub("(%d%d%d)", "%1."):reverse()
    if formatted:sub(1, 1) == "." then
        formatted = formatted:sub(2)
    end
    return sign .. formatted
end

function bringFloatTo(from, to, start_time, duration)
    local timer = os.clock() - start_time
    if timer >= 0.00 and timer <= duration then
        local count = timer / (duration / 100)
        return from + (count * (to - from) / 100), true
    end
    return (timer > duration) and to or from, false
end

function limit(v, min, max)
	min, max = min or 0.0, max or 1.0
	return v < min and min or (v > max and max or v)
end

function begin_edit_position(element)
	while imgui.IsMouseDown(0) do wait(0) end
	settings[0] = false
	local current_x, current_y

	if element == "hp" then
		current_x, current_y = pos_hp_x[0], pos_hp_y[0]
	elseif element == "armor" then
		current_x, current_y = pos_armor_x[0], pos_armor_y[0]
	elseif element == "satiety" then
		current_x, current_y = pos_satiety_x[0], pos_satiety_y[0]
	elseif element == "money" then
		current_x, current_y = pos_money_x[0], pos_money_y[0]
	elseif element == "ammo" then
		current_x, current_y = pos_ammo_x[0], pos_ammo_y[0]
	end

	process_position = { ini.main.x, ini.main.y }
	sampSetCursorMode(4)
	sampAddChatMessage("{eb4034}HassleHUD{FFFFFF} - Mutati cursorul pentru a modifica " .. element .. ". ", -1)
	sampAddChatMessage('{FFFFFF}CLICK STANGA{eb4034} pentru a salva, {FFFFFF}ESC{eb4034} pentru a anula!', -1)

	local base_x, base_y = getCursorPos()

	while process_position ~= nil do
		local cursor_x, cursor_y = getCursorPos()
		local offset_x = cursor_x - base_x
		local offset_y = cursor_y - base_y

		if element == "hp" then
			pos_hp_x[0] = current_x + offset_x
			pos_hp_y[0] = current_y + offset_y
		elseif element == "armor" then
			pos_armor_x[0] = current_x + offset_x
			pos_armor_y[0] = current_y + offset_y
		elseif element == "satiety" then
			pos_satiety_x[0] = current_x + offset_x
			pos_satiety_y[0] = current_y + offset_y
		elseif element == "money" then
			pos_money_x[0] = current_x + offset_x
			pos_money_y[0] = current_y + offset_y
		elseif element == "ammo" then
			pos_ammo_x[0] = current_x + offset_x
			pos_ammo_y[0] = current_y + offset_y
		end
		wait(0)
	end
	sampSetCursorMode(0)
	edit_mode[0] = 0
end

function begin_change_position()
	while imgui.IsMouseDown(0) do wait(0) end
	settings[0] = false
    process_position = { ini.main.x, ini.main.y }
    sampSetCursorMode(4)
    sampAddChatMessage("{eb4034}Made by allecsei {FFFFFF} - Mutati cursorul in pozitia dorita, iar {FFFFFF}ESC{eb4034} pentru a anula",-1)
    while process_position ~= nil do
        local x, y = getCursorPos()
        ini.main.x = x
        ini.main.y = y
        wait(0)
    end
    sampSetCursorMode(0)
    settings[0] = true
end

function onWindowMessage(msg, wp, lp)
	if process_position then
		if msg == 0x0201 then
			if edit_mode[0] ~= 0 then
				local element
				if edit_mode[0] == 1 then element = "hp"
				elseif edit_mode[0] == 2 then element = "armor"
				elseif edit_mode[0] == 3 then element = "satiety"
				elseif edit_mode[0] == 4 then element = "money"
				elseif edit_mode[0] == 5 then element = "ammo"
				end

				if element == "hp" then
					ini.position.hp_x = pos_hp_x[0]
					ini.position.hp_y = pos_hp_y[0]
				elseif element == "armor" then
					ini.position.armor_x = pos_armor_x[0]
					ini.position.armor_y = pos_armor_y[0]
				elseif element == "satiety" then
					ini.position.satiety_x = pos_satiety_x[0]
					ini.position.satiety_y = pos_satiety_y[0]
				elseif element == "money" then
					ini.position.money_x = pos_money_x[0]
					ini.position.money_y = pos_money_y[0]
				elseif element == "ammo" then
					ini.position.ammo_x = pos_ammo_x[0]
					ini.position.ammo_y = pos_ammo_y[0]
				end

				inicfg.save(ini, "HassleHUD.ini")
				sampAddChatMessage("{eb4034}Pozitia pentru " .. element .. " a fost salvata!", -1)
				process_position = nil; consumeWindowMessage()
			else
				inicfg.save(ini, "HassleHUD.ini")
				sampAddChatMessage("{eb4034}Pozitia a fost salvata!", -1)
				process_position = nil; consumeWindowMessage()
			end
		elseif msg == 0x0100 and wp == 0x1B then
			if edit_mode[0] ~= 0 then
				local element
				if edit_mode[0] == 1 then element = "hp"
				elseif edit_mode[0] == 2 then element = "armor"
				elseif edit_mode[0] == 3 then element = "satiety"
				elseif edit_mode[0] == 4 then element = "money"
				elseif edit_mode[0] == 5 then element = "ammo"
				end

				if element == "hp" then
					pos_hp_x[0] = ini.position.hp_x
					pos_hp_y[0] = ini.position.hp_y
				elseif element == "armor" then
					pos_armor_x[0] = ini.position.armor_x
					pos_armor_y[0] = ini.position.armor_y
				elseif element == "satiety" then
					pos_satiety_x[0] = ini.position.satiety_x
					pos_satiety_y[0] = ini.position.satiety_y
				elseif element == "money" then
					pos_money_x[0] = ini.position.money_x
					pos_money_y[0] = ini.position.money_y
				elseif element == "ammo" then
					pos_ammo_x[0] = ini.position.ammo_x
					pos_ammo_y[0] = ini.position.ammo_y
				end

				sampAddChatMessage("{eb4034}Nu s-au salvat modificarile pentru " .. element, -1)
				process_position = nil; consumeWindowMessage()
			else
				ini.main.x = process_position[1]
				ini.main.y = process_position[2]
				sampAddChatMessage("{eb4034}Nu s-au salvat modificarile pozitiei", -1)
				process_position = nil; consumeWindowMessage()
			end
		end
	else
		-- Cand nu suntem in modul de editare pozitie, ESC inchide meniurile pe rand
		if msg == 0x0100 and wp == 0x1B then
			-- Mai intai inchide meniul de teme (popup), apoi meniul principal
			if show_theme_menu[0] then
				show_theme_menu[0] = false
				consumeWindowMessage()
			elseif settings[0] then
				settings[0] = false
				consumeWindowMessage()
			end
		end
	end
end

