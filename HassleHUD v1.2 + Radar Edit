function main()
	while not isSampAvailable() do wait(0) end
	if orig_hud[0] == false then displayHud(false) end
	sampAddChatMessage("{eb4034}HassleHUD {FFFFFF}made by {eb4034}allecsei {FFFFFF}| Comanda: {eb4034}/hassle", 0xFFFFFF)
	sampAddChatMessage("{eb4034}HassleHUD {FFFFFF}F7 toggle: Normal -> Transparent -> Hidden -> Normal", 0xFFFFFF)
	
	-- Incarcam config radar
	loadRadarConfig()
	while not sampIsLocalPlayerSpawned() do wait(0) end
	radar_spawned = true
	radar_applyAll()

	sampRegisterChatCommand("hassle", function()
		settings[0] = not settings[0]
	end)

	while true do
		wait(0)

		if not radar_spawned and sampIsLocalPlayerSpawned() then
			radar_spawned = true
			radar_applyAll()
		elseif radar_spawned and not sampIsLocalPlayerSpawned() then
			radar_spawned = false
		end

		-- F7 key handling for HUD visibility toggle
		-- State 0 = normal, 1 = semi-transparent, 2 = hidden
		if isKeyDown(0x76) then -- VK_F7 = 0x76
			if not f7_key_pressed then
				f7_key_pressed = true

				if hud_visibility_state[0] == 0 then		
					hud_visibility_state[0] = 1
					sampAddChatMessage("{eb4034}HassleHUD {FFFFFF}HUD: Semi-transparent (30%)", 0xFFFFFF)
				elseif hud_visibility_state[0] == 1 then				
					hud_visibility_state[0] = 2
					sampAddChatMessage("{eb4034}HassleHUD {FFFFFF}HUD: Hidden", 0xFFFFFF)
				else			
					hud_visibility_state[0] = 0
					sampAddChatMessage("{eb4034}HassleHUD {FFFFFF}HUD: Normal", 0xFFFFFF)
				end
			end
		else
			f7_key_pressed = false
		end
	end
end

function se.onShowDialog(id, style, title, button1, button2, text)
	if SE_AWAIT then
		local count = string.match(text, "(%d+%.?%d*)%s*/%s*100%.0")
		if count ~= nil then
			SE_AWAIT = false
			satiety.count = tonumber(count)
			lua_thread.create(function()
				wait(300)
				sampSendDialogResponse(id, 0, nil, nil)
			end)
			return false
		end
	end
end

