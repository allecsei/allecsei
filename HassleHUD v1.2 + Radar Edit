	function() return not isPauseMenuActive() and not sampIsScoreboardOpen() and hud_visibility_state[0] < 2 end,
	function(self)
		self.HideCursor = true

		local alpha_mult = (hud_visibility_state[0] == 1) and 0.3 or 1.0

		local DL = imgui.GetBackgroundDrawList()
		local x, y = ini.main.x, ini.main.y

		local radius = ({ 40, 60, 80, })[hudSize[0]]
		local polygons = radius * 1.5

		do
			local inWater = isCharInWater(PLAYER_PED)
			if settings[0] or process_position then inWater = true end
			if anim_breath.state ~= inWater then
				anim_breath.state = inWater
				anim_breath.timer = os.clock()
			end

			if anim_breath.timer ~= nil then
				local max_thickness = (radius / 100) * 5
				local thickness = 0
				if anim_breath.state then
					thickness = bringFloatTo(0, max_thickness, anim_breath.timer, anim_breath.duration)
				else
					thickness = bringFloatTo(max_thickness, 0, anim_breath.timer, anim_breath.duration)
				end

				local breath = limit(getReserveOfBreath(), 0, 100)
				if settings[0] or process_position then breath = 100 end
				local rotation = 180 - (360 / 100) * (breath / 2)
				local alpha = (thickness / max_thickness) * alpha_mult
				local r, g, b = table.unpack(ini.color_be)
				local color = imgui.ImVec4(r, g, b, alpha)
				local _radius = radius + (thickness / 2) - 1

				if thickness > 0 then
					local a1 = 90 - (360 / 100) * (breath / 2)
					local a2 = 90 + (360 / 100) * (breath / 2)

					DL:PathClear()
			        DL:PathArcTo(imgui.ImVec2(x, y), radius, math.rad(a1), math.rad(a2), polygons)
			        local bg_color = imgui.ImVec4(r, g, b, (alpha / 10) * alpha_mult)
					DL:PathFillConvex(u32(bg_color))

					DL:PathClear()
			        DL:PathArcTo(imgui.ImVec2(x, y), radius, math.rad(a1), math.rad(a2), polygons)
					DL:PathStroke(u32(color), false, thickness)

				    if values[0] then
						imgui.PushFont(font_min)
						local text = string.format("%d%%", breath)
						local ts = imgui.CalcTextSize(text)
						local pos = imgui.ImVec2(x - (ts.x / 2), y + radius - ts.y - 5)
						DL:AddText(imgui.ImVec2(pos.x + 1, pos.y + 1), 0x70000000, text)
						DL:AddText(pos, u32(imgui.ImVec4(1, 1, 1, alpha)), text)
						imgui.PopFont()
					end
				end
			end
		end

		local weapon_id = getCurrentCharWeapon(PLAYER_PED)
		if weapons[weapon_id] ~= nil then
			local size = imgui.ImVec2(radius * 1.3, radius * 1.5)
			local A = imgui.ImVec2(x - size.x / 2, y - size.y / 2)
			local B = imgui.ImVec2(A.x + size.x, A.y + size.y)
			local weapon_alpha = alpha_mult
			DL:AddImage(weapons[weapon_id], A, B, nil, nil, nil, nil, nil, weapon_alpha)
		end

		local ammo = getAmmoInCharWeapon(PLAYER_PED, weapon_id)
		if ammo > 0 then
			local clip = getAmmoInClip()
			local text = string.format("%d/%d", clip, ammo)
			local len = imgui.CalcTextSize(text).x
