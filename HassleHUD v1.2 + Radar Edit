			DL:AddRectFilled(A, B, u32(imgui.ImVec4(r, g, b, 0.30 * alpha_mult)), rounding, imgui.DrawCornerFlags.TopLeft + imgui.DrawCornerFlags.BotRight)
			B.x = A.x + (len[2] / 100) * ap
