local function radar_freeOne(p)
    if p ~= nil then
        libc.free(p)
    end
end

local function radar_allocf(v)
    local p = ffi.cast("float*", libc.malloc(4))
    p[0] = v
    return p
end

local function radar_applyX(v)
    radar_freeOne(rpx)
    rpx = radar_allocf(v)
    ffi.cast("float**", 0x58A79B)[0] = rpx
    ffi.cast("float**", 0x5834D4)[0] = rpx
    ffi.cast("float**", 0x58A836)[0] = rpx
    ffi.cast("float**", 0x58A8E9)[0] = rpx
