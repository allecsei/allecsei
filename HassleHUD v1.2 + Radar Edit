			imgui.SetCursorPosX(15)
			imgui.SetCursorPosY(15)
			imgui.TextColored(imgui.ImVec4(1, 1, 1, 1), u8("ALEGE O TEMA"))
		imgui.EndChild()
		imgui.PopStyleColor()

		imgui.SetCursorPosY(imgui.GetCursorPosY() + 10)

		-- GRID TEME 3x3
		local theme_grid = {
			{ themes[0].name, themes[0].header, 0 },
			{ themes[1].name, themes[1].header, 1 },
			{ themes[2].name, themes[2].header, 2 },
			{ themes[3].name, themes[3].header, 3 },
			{ themes[4].name, themes[4].header, 4 },
			{ themes[5].name, themes[5].header, 5 },
			{ themes[6].name, themes[6].header, 6 },
			{ themes[7].name, themes[7].header, 7 },
			{ themes[8].name, themes[8].header, 8 },
		}

		local btnW, btnH = 150, 60
		local startX = (PW - 20 - (btnW * 3 + 15)) / 2

		for i, theme_data in ipairs(theme_grid) do
			local isSelected = current_theme[0] == theme_data[3]
			local col = (i - 1) % 3
			local row = math.floor((i - 1) / 3)

			if i == 1 then
				imgui.SetCursorPosX(startX)
			elseif col == 0 and i > 1 then
				if row > 0 then imgui.SetCursorPosY(imgui.GetCursorPosY() + 10) end
				imgui.SetCursorPosX(startX)
			else
